{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "backend",
      "runtimeExecutable": "backend/venv/bin/python",
      "runtimeArgs": ["backend/manage.py", "runserver", "127.0.0.1:8000"],
      "port": 8000,
      "autoPort": false
    },
    {
      "name": "frontend",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["--prefix", "frontend", "run", "dev"],
      "port": 5173
    },
    {
      "name": "chancery-next",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["--prefix", "chancery-next", "run", "dev"],
      "port": 3000
    }
  ]
}
